# Postgres connection string (e.g. from a free Neon project: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Random secret used to sign NextAuth session tokens/cookies.
# Generate one with: npx auth secret
AUTH_SECRET=""

# Base URL of the app, used to build magic-link and invite URLs.
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google Books API key (https://console.cloud.google.com/apis/library/books.googleapis.com).
# Works without a key at low request volume, but a key raises the rate limit.
GOOGLE_BOOKS_API_KEY=""
